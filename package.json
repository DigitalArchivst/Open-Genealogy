{
  "name": "open-genealogy-publication-checks",
  "private": true,
  "version": "1.0.0",
  "description": "Pinned local publication checks for Open-Genealogy.",
  "engines": {
    "node": "22.18.0"
  },
  "scripts": {
    "lint:markdown": "npm run lint:markdown:baseline",
    "lint:markdown:baseline": "markdownlint \"**/*.md\" --ignore node_modules",
    "lint:markdown:changed": "python scripts/check_markdown_changes.py"
  },
  "devDependencies": {
    "markdownlint-cli": "0.49.0"
  }
}
